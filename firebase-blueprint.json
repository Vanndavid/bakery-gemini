{
  "entities": {
    "MenuItem": {
      "title": "Menu Item",
      "description": "An item on the bakery menu.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the menu item."
        },
        "description": {
          "type": "string",
          "description": "A description of the menu item."
        },
        "price": {
          "type": "number",
          "description": "The price of the menu item."
        },
        "category": {
          "type": "string",
          "description": "The category of the menu item (e.g., Bread, Pastry, Cake)."
        },
        "imageUrl": {
          "type": "string",
          "description": "URL of the menu item image."
        }
      },
      "required": ["name", "price", "category"]
    },
    "GalleryImage": {
      "title": "Gallery Image",
      "description": "An image in the bakery gallery.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the image."
        },
        "imageUrl": {
          "type": "string",
          "description": "URL of the gallery image."
        },
        "description": {
          "type": "string",
          "description": "A description of the image."
        }
      },
      "required": ["title", "imageUrl"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "appName": {
          "type": "string",
          "description": "The name of the application."
        },
        "colorScheme": {
          "type": "string",
          "description": "The color scheme of the application.",
          "enum": ["amber", "rose", "emerald", "slate"]
        }
      },
      "required": ["appName", "colorScheme"]
    },
    "Sale": {
      "title": "Sale Record",
      "description": "A record of a completed sale from the POS system.",
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "description": "The items included in the sale",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "subtotal": { "type": "number" }
            },
            "required": ["id", "name", "price", "quantity", "subtotal"]
          }
        },
        "total": {
          "type": "number",
          "description": "Total amount for the sale"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the sale occurred"
        },
        "userId": {
          "type": "string",
          "description": "The ID of the admin who performed the sale"
        }
      },
      "required": ["items", "total", "timestamp", "userId"]
    }
  },
  "firestore": {
    "/sales/{saleId}": {
      "schema": {
        "$ref": "#/entities/Sale"
      },
      "description": "Collection of sale records."
    },
    "/settings/{settingId}": {
      "schema": {
        "$ref": "#/entities/Settings"
      },
      "description": "Global application settings. Usually just one document 'global'."
    },
    "/menu/{menuId}": {
      "schema": {
        "$ref": "#/entities/MenuItem"
      },
      "description": "Collection of bakery menu items."
    },
    "/gallery/{imageId}": {
      "schema": {
        "$ref": "#/entities/GalleryImage"
      },
      "description": "Collection of bakery gallery images."
    }
  }
}
